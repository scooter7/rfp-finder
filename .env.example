# ============================================================
# Supabase
# ============================================================
# From your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose. Bypasses RLS for ingestion jobs.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# LLM providers
# ============================================================
# https://console.anthropic.com — used for RFP classification (Haiku)
ANTHROPIC_API_KEY=

# https://platform.openai.com — used for embeddings (text-embedding-3-small)
# Swap for Voyage AI later if you want better retrieval quality
OPENAI_API_KEY=

# ============================================================
# Data sources
# ============================================================
# https://sam.gov/data-services — free, rate-limited to 1000/hr on public tier
# Request at https://open.gsa.gov/api/get-opportunities-public-api/
SAM_GOV_API_KEY=

# Optional: Firecrawl for scraping non-API state portals (Phase 2)
# https://firecrawl.dev
FIRECRAWL_API_KEY=

# ============================================================
# Cron (Vercel)
# ============================================================
# Ingestion + alerts run as Vercel Cron routes under /api/cron/*.
# Vercel automatically sends `Authorization: Bearer $CRON_SECRET`
# when invoking them; the routes reject requests without it.
# Set any strong random string.
CRON_SECRET=

# ============================================================
# Notifications (Phase 1.5 — alerts)
# ============================================================
# https://resend.com
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@yourdomain.com
